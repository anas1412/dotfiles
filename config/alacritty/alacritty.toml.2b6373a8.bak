[window]
padding = { x = 15, y = 15 }
decorations = "Full"
opacity = 0.0
blur = true

[font]
size = 11

[font.normal]
family = "JetBrainsMono Nerd Font"
style = "Regular"

[font.bold]
family = "JetBrainsMono Nerd Font"
style = "Bold"

[font.italic]
family = "JetBrainsMono Nerd Font"
style = "Italic"

[window.dimensions]
columns = 80
lines = 28
